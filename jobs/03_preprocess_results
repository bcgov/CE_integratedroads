#!/bin/bash
set -euxo pipefail

# ----
# convert RESULTS polygon roads to lines
# ----

PSQL="psql $DATABASE_URL -v ON_ERROR_STOP=1"

ogr2ogr \
  -f PostgreSQL \
  "PG:$DATABASE_URL" \
  -append \
  --config OGR_TRUNCATE=YES \
  -nln whse_basemapping.bcgs_20k_grid \
  /vsis3/$BUCKET/sources/whse_basemapping.bcgs_20k_grid.parquet \
  whse_basemapping.bcgs_20k_grid

ogr2ogr \
  -f PostgreSQL \
  "PG:$DATABASE_URL" \
  -nln whse_forest_vegetation.rslt_forest_cover_inv_svw \
  -lco GEOMETRY_NAME=geom \
  -overwrite \
  -select forest_cover_id,map_tile \
  /vsis3/$BUCKET/sources/whse_forest_vegetation.rslt_forest_cover_inv_svw.parquet \
  whse_forest_vegetation.rslt_forest_cover_inv_svw

$PSQL -c "SELECT COUNT(*) FROM whse_forest_vegetation.rslt_forest_cover_inv_svw"

$PSQL -c "DROP TABLE IF EXISTS results"

$PSQL -c "CREATE TABLE results (
  results_id serial primary key,
  map_tile character varying,
  geom geometry(Linestring, 3005)
)"

$PSQL -tXA \
-c "SELECT DISTINCT map_tile
    FROM whse_forest_vegetation.rslt_forest_cover_inv_svw
    WHERE ST_ISValid(geom)
    ORDER BY map_tile" \
    | parallel --tag \
      $PSQL -f sql/roadpoly2line.sql \
        -v tile={1} \
        -v in_table=whse_forest_vegetation.rslt_forest_cover_inv_svw \
        -v out_table=results

# dump to local file (required for indexing)
ogr2ogr \
  -f Parquet \
  /tmp/results.parquet \
  PG:$DATABASE_URL \
  -lco COMPRESSION=ZSTD \
  -lco COMPRESSION_LEVEL=15 \
  -lco SORT_BY_BBOX=YES \
  -sql "select * from results"

# upload
aws s3 cp /tmp/results.parquet s3://$BUCKET/cleaned/results.parquet